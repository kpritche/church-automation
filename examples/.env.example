# Church Automation Environment Configuration
# Copy this file to .env and fill in your actual credentials

# Planning Center Online API Credentials
# Get these from: https://api.planningcenteronline.com/oauth/applications
PCO_CLIENT_ID=your_planning_center_client_id_here
PCO_SECRET=your_planning_center_secret_or_pat_here

# GCP Service Account Credentials (optional - for Vertex AI text summarization)
# Filename should be placed in your secrets directory (~/.church-automation/)
GCP_CREDENTIALS_FILENAME=gcp-credentials.json

# Website URL for Fetching Announcements
# This URL should point to the page listing the weekly events or announcements.
ANNOUNCEMENTS_WEBSITE_URL=https://www.fumcwl.org/weekly-events/

# Secrets Directory (optional - defaults to ~/.church-automation)
# This is where GCP credentials for AI summarization are stored
# CHURCH_AUTOMATION_SECRETS_DIR=/path/to/secrets

# AI Summarization Setup (optional):
# 1. Enable Vertex AI API in Google Cloud Console
# 2. Create a service account and download the JSON key
# 3. Save as 'gcp-credentials.json' in your secrets directory

# Optional: Override default config file locations
# SLIDES_CONFIG=/path/to/slides_config.json
# EXPORT_DIR=/path/to/export/directory
