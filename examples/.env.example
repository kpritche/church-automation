# Church Automation Environment Configuration
# Copy this file to .env and fill in your actual credentials

# Planning Center Online API Credentials
# Get these from: https://api.planningcenteronline.com/oauth/applications
PCO_CLIENT_ID=your_planning_center_client_id_here
PCO_SECRET=your_planning_center_secret_or_pat_here

# GCP Service Account Credentials (optional - for Vertex AI text summarization)
# Filename should be placed in your secrets directory (~/.church-automation/)
GCP_CREDENTIALS_FILENAME=gcp-credentials.json

# Gmail Query for Fetching Announcements
# Customize the sender and subject line to match your church's announcement emails
GMAIL_ANNOUNCEMENTS_QUERY=from:"Your Church Name" subject:"Your Announcement Subject"

# Secrets Directory (optional - defaults to ~/.church-automation)
# This is where Gmail OAuth tokens and GCP credentials are stored
# CHURCH_AUTOMATION_SECRETS_DIR=/path/to/secrets

# Gmail Credentials Setup:
# Place these files in your secrets directory (~/.church-automation/ by default):
#
# 1. credentials.json
#    - Gmail API OAuth 2.0 Client ID credentials
#    - Download from Google Cloud Console: https://console.cloud.google.com/apis/credentials
#    - Enable Gmail API for your project
#
# 2. announcements_token.pickle
#    - Auto-generated on first run after OAuth authentication
#    - Will be created automatically when you run the announcements script
#
# 3. gmail-pptx-tool-XXXXX.json (optional)
#    - GCP service account credentials for Google Vertex AI (if using AI summarization)
#    - Download from Google Cloud Console: https://console.cloud.google.com/iam-admin/serviceaccounts

# Optional: Override default config file locations
# SLIDES_CONFIG=/path/to/slides_config.json
# EXPORT_DIR=/path/to/export/directory
