# Copy this file to ~/.church-automation/bulletins-email.env and fill in values.
# Ensure permissions are restricted:
#   chmod 600 ~/.church-automation/bulletins-email.env

# SMTP settings
BULLETIN_SMTP_HOST=smtp.gmail.com
BULLETIN_SMTP_PORT=587
BULLETIN_SMTP_USER=your-account@example.com
BULLETIN_SMTP_PASS=your-app-password

# Comma-separated recipient list
BULLETIN_EMAIL_TO=person1@example.com,person2@example.com

# Optional settings
BULLETIN_EMAIL_LOOKBACK_MINUTES=180
BULLETIN_EMAIL_SUBJECT=New Church Bulletins
BULLETIN_EMAIL_BODY=Attached are the newly generated bulletin PDFs.
